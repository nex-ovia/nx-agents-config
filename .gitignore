# Built binary (produced by build.sh)
/nx-agents-config

# User data store (separate git repo, user controls their remote)
/store/

# Generated symlinks (created by setup/update)
/store/*/skills
/store/*/plugins

# Runtime data
/shared/memory/*
!/shared/memory/.gitkeep

# OS files
.DS_Store
*.log
*.swp
*.swo

# Empty dir placeholders
!.gitkeep
