# User data store (separate git repo, user controls their remote)
/store/

# Generated symlinks (created by setup/update)
opencode/skills
opencode/plugins
claude/skills

# Runtime data
shared/memory/*
!shared/memory/.gitkeep

# Claude Desktop runtime cruft
claude/ide/
claude/sessions/
claude/projects/
claude/*.json
*.lock

# Build artifacts
opencode/**/node_modules/

# OS files
.DS_Store
*.log
*.swp
*.swo

# Empty dir placeholders (we use .gitkeep convention)
!.gitkeep
