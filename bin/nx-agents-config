#!/usr/bin/env bash
# nx-agents-config — CLI entry point
# Resolves REPO_DIR (handles symlinks), sources src/main.sh
set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
while [[ -L "$SCRIPT_PATH" ]]; do
  SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"
done
REPO_DIR="$(cd "$(dirname "$SCRIPT_PATH")/.." && pwd)"

source "$REPO_DIR/src/main.sh"
